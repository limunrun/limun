{
    "imports": {
        "foo": "./examples/foo.js",
        "bar": "./examples/bar.js",
        "examples/": "./examples/",
        "blocked-example": null
    },
    "scopes": {
        "./examples/": {
            "bar": "./examples/scoped-bar.js"
        }
    },
    "permissions": {
        "io": {
            "default": false,
            "file://**": { "read": true },
            "https://esm.sh/": { "read": true },
            "https://raw.githubusercontent.com/": { "read": true },
            "ws://127.0.0.1:8787/": { "read": true }
        }
    }
}